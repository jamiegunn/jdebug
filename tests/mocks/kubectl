#!/bin/sh
# Test double for kubectl. Behavior is driven by env vars so tests can script
# every failure mode without a cluster:
#   MOCK_KUBECTL   ok (default) | x509 | refused | noctx   — /version probe result
#   MOCK_PODS      one (default) | none | multi            — pod listings
#   MOCK_EXEC_OUT  what an in-pod `exec` prints            — default "ok"
#   MOCK_ACTUATOR  secured|absent|badpage                  — actuator fetch outcome
#                  (secured→401, absent→404, badpage→200 HTML login on heapdump)
#   MOCK_LOG       file to append every invocation to (for asserting calls)
[ -n "${MOCK_LOG:-}" ] && printf '%s\n' "$*" >> "$MOCK_LOG"

#   MOCK_RBAC      forbidden — namespace/pod enumeration fails like real RBAC
if [ "${MOCK_RBAC:-}" = forbidden ]; then
    case "$*" in
        *"get namespaces"*|*"get pods"*|*" get pod "*)
            echo 'Error from server (Forbidden): pods is forbidden: User "dev" cannot list resource "pods" in API group "" in the namespace "default"' >&2
            exit 1 ;;
    esac
fi

case "$*" in
    *"get --raw=/version"*)
        case "${MOCK_KUBECTL:-ok}" in
            ok)      echo '{"major":"1","minor":"31"}'; exit 0 ;;
            x509)    echo 'Unable to connect to the server: tls: failed to verify certificate: x509: certificate signed by unknown authority' >&2; exit 1 ;;
            refused) echo 'The connection to the server 127.0.0.1:6443 was refused - connection refused' >&2; exit 1 ;;
            noctx)   echo 'error: current-context is not set' >&2; exit 1 ;;
        esac ;;
    "config current-context")
        [ "${MOCK_KUBECTL:-ok}" = noctx ] && { echo 'error: current-context is not set' >&2; exit 1; }
        echo 'mock-ctx' ;;
    *"config get-contexts"*)
        printf 'ctx-a\nmock-ctx\n' ;;
    *"config use-context"*)
        echo "Switched to context." ;;
    *"get namespaces"*)
        printf 'default\npayments\n' ;;
    *"labels.app"*)
        case "${MOCK_PODS:-one}" in
            none) exit 0 ;;
            *)    printf 'payments\npayments\nweb\n' ;;
        esac ;;
    *" get pod "*"-o name"*)
        [ "${MOCK_POD_GONE:-}" = 1 ] && exit 1
        echo "pod/pod-x" ;;
    *" get pod "*jsonpath*)
        printf 'app\nsidecar\n' ;;
    *" get pod "*"-o json"*)
        [ "${MOCK_POD_GONE:-}" = 1 ] && exit 1
        if [ "${MOCK_CONTEXT:-}" = 1 ]; then
            # rich pod for `jdebug context`: env (incl. JVM + redis + a secretKeyRef),
            # envFrom, probes, volumes (tmpfs + PVC + configMap + secret)
            printf '{"metadata":{"name":"pod-a","labels":{"app":"payments"},"ownerReferences":[{"kind":"ReplicaSet","name":"app-6c6c4b5769"}]},"status":{"phase":"Running"},"spec":{"volumes":[{"name":"cache","emptyDir":{"medium":"Memory"}},{"name":"data","persistentVolumeClaim":{"claimName":"payments-pvc"}},{"name":"cfg","configMap":{"name":"redis-config"}},{"name":"creds","secret":{"secretName":"app-secrets"}}],"containers":[{"name":"app","image":"reg/payments:1.4.2","command":["java"],"args":["-jar","app.jar"],"volumeMounts":[{"name":"cache","mountPath":"/tmp/cache"},{"name":"data","mountPath":"/data","readOnly":true},{"name":"cfg","mountPath":"/etc/redis"}],"readinessProbe":{"httpGet":{"path":"/actuator/health/readiness","port":8080},"initialDelaySeconds":10,"periodSeconds":5,"timeoutSeconds":2,"failureThreshold":3},"livenessProbe":{"httpGet":{"path":"/actuator/health/liveness","port":8080},"periodSeconds":10,"failureThreshold":3},"env":[{"name":"JAVA_TOOL_OPTIONS","value":"-XX:MaxRAMPercentage=75"},{"name":"SPRING_PROFILES_ACTIVE","value":"prod,cluster"},{"name":"TZ","value":"UTC"},{"name":"HTTPS_PROXY","value":"http://proxy:3128"},{"name":"SPRING_DATA_REDIS_HOST","value":"valkey.svc"},{"name":"SPRING_DATA_REDIS_PASSWORD","valueFrom":{"secretKeyRef":{"name":"app-secrets","key":"redis-pw"}}},{"name":"DB_URL","valueFrom":{"configMapKeyRef":{"name":"app-config","key":"db-url"}}}],"envFrom":[{"configMapRef":{"name":"app-config"}},{"secretRef":{"name":"app-secrets"}}]}]}}'
            exit 0
        fi
        printf '{"metadata":{"name":"pod-a","labels":{"app":"payments"},"creationTimestamp":"2026-07-05T14:00:05Z","ownerReferences":[{"kind":"ReplicaSet","name":"app-6c6c4b5769"}]},"status":{"phase":"Running","qosClass":"Burstable","containerStatuses":[{"name":"app","image":"reg/payments:1.4.2","imageID":"reg/payments@sha256:abc123","restartCount":3,"state":{"running":{"startedAt":"2026-07-05T14:05:30Z"}},"lastState":{"terminated":{"reason":"OOMKilled","exitCode":137,"finishedAt":"2026-07-05T14:05:20Z"}}}]},"spec":{"serviceAccountName":"default","containers":[{"name":"app","image":"reg/payments:1.4.2","resources":{"requests":{"memory":"256Mi","cpu":"100m"},"limits":{"memory":"512Mi","cpu":"500m"}},"livenessProbe":{"httpGet":{"path":"/actuator/health","port":8080},"periodSeconds":10,"failureThreshold":3}}]}}' ;;
    *"get endpoints"*"-o json"*)
        printf '{"items":[{"metadata":{"name":"app"},"subsets":[{"addresses":[{"ip":"10.0.0.5","targetRef":{"name":"pod-a"}}]}]}]}' ;;
    *"get configmap"*"-o json"*)
        # a mounted redis.conf with cluster-announce settings (the classic footgun)
        printf '{"metadata":{"name":"redis-config"},"data":{"redis.conf":"cluster-enabled yes\\ncluster-announce-ip 10.1.2.3\\ncluster-announce-port 6379\\nrequirepass supersecret\\nmaxmemory 512mb\\nmaxmemory-policy allkeys-lru\\n"}}' ;;
    *"get deployment"*"-o json"*)
        # rich enough for both why.sh (last-applied replicas) and topology.sh
        # (kind, revision, status, template labels)
        printf '{"kind":"Deployment","metadata":{"name":"app","annotations":{"deployment.kubernetes.io/revision":"3","kubectl.kubernetes.io/last-applied-configuration":"{\\"spec\\":{\\"replicas\\":3}}"}},"spec":{"replicas":3,"strategy":{"type":"RollingUpdate"},"template":{"metadata":{"labels":{"app":"payments"}}}},"status":{"readyReplicas":2,"updatedReplicas":2,"availableReplicas":2}}' ;;
    *"get hpa -o json"*|*"get hpa"*"-o json"*)
        printf '{"items":[{"metadata":{"name":"app-hpa"},"spec":{"scaleTargetRef":{"kind":"Deployment","name":"app"},"minReplicas":2,"maxReplicas":10,"metrics":[{"resource":{"name":"cpu","target":{"averageUtilization":80}}}]},"status":{"currentReplicas":3,"desiredReplicas":3,"conditions":[{"type":"ScalingActive","status":"False","reason":"FailedGetResourceMetric"}]}}]}' ;;
    *"get networkpolicy"*)
        printf '{"items":[]}' ;;
    *"get rs"*"-o json"*)
        # topology: current revision-3 RS + an old revision-2 RS still running a pod
        printf '{"items":[{"metadata":{"name":"app-6c6c4b5769","annotations":{"deployment.kubernetes.io/revision":"3"},"ownerReferences":[{"kind":"Deployment","name":"app"}]},"spec":{"replicas":3},"status":{"readyReplicas":2}},{"metadata":{"name":"app-59d8ff7c44","annotations":{"deployment.kubernetes.io/revision":"2"},"ownerReferences":[{"kind":"Deployment","name":"app"}]},"spec":{"replicas":1},"status":{"readyReplicas":1}}]}' ;;
    *"get svc"*"-o json"*)
        printf '{"items":[{"metadata":{"name":"app"},"spec":{"type":"ClusterIP","clusterIP":"10.96.0.20","selector":{"app":"payments"},"ports":[{"name":"http","port":80,"targetPort":8080,"protocol":"TCP"}]}}]}' ;;
    *" top pod "*)
        if [ "${MOCK_TOP:-}" = absent ]; then
            echo 'error: Metrics API not available' >&2; exit 1
        fi
        printf 'pod-a   250m   480Mi\n' ;;
    *"get hpa"*"--no-headers"*)
        printf 'app-hpa   Deployment/app   cpu: 50%%/80%%   2   4   3   10h\n' ;;
    *"get pods -o json")
        # end-anchored: "-o jsonpath" also contains "-o json" and must NOT
        # match here (that swallowing bug has bitten before).
        # labels for selector discovery: two payments pods + one web pod,
        # with rollout hashes that must never be suggested
        printf '{"items":[{"metadata":{"name":"pod-a","labels":{"app":"payments","app.kubernetes.io/name":"payments","component":"api","pod-template-hash":"abc123"}}},{"metadata":{"name":"pod-b","labels":{"app":"payments","app.kubernetes.io/name":"payments","component":"api","pod-template-hash":"abc123"}}},{"metadata":{"name":"pod-c","labels":{"app":"web","pod-template-hash":"zzz999"}}}]}' ;;
    *"get pods"*jsonpath*)
        case "${MOCK_PODS:-one}" in
            none)  exit 0 ;;
            one)   echo 'pod-a' ;;
            multi) printf 'pod-a\npod-b\npod-c\n' ;;
        esac ;;
    *"get pods"*"-o wide"*)
        printf 'NAME    READY   STATUS    RESTARTS   AGE\npod-a   1/1     Running   3          2d\n' ;;
    *"get events"*"-o json"*)
        printf '{"items":[{"type":"Normal","reason":"Scheduled","message":"Successfully assigned default/pod-a","lastTimestamp":"2026-07-05T14:00:00Z","count":1},{"type":"Normal","reason":"Pulled","message":"Container image already present on machine","lastTimestamp":"2026-07-05T14:01:00Z","count":1},{"type":"Warning","reason":"BackOff","message":"Back-off restarting failed container app","lastTimestamp":"2026-07-05T14:05:00Z","count":7}]}' ;;
    *"get events"*)
        echo '5m  Warning  BackOff  pod/pod-a  Back-off restarting failed container' ;;
    *"top pods"*)
        printf 'NAME    CPU(cores)   MEMORY(bytes)\npod-a   250m         480Mi\n' ;;
    *"get hpa"*)
        echo 'No resources found.' ;;
    *" exec "*)
        # actuator failure simulation: the in-pod snippet carries the URL and,
        # for a status probe, curl's %{http_code}. Match those to script 4xx.
        case "$*" in
            *"%{http_code}"*)  # a pod_http_status probe
                case "${MOCK_ACTUATOR:-}" in
                    secured) echo 401 ;; absent) echo 404 ;; *) echo 200 ;;
                esac; exit 0 ;;
            *heapdump*|*threaddump*)
                case "${MOCK_ACTUATOR:-}" in
                    secured|absent) exit 22 ;;   # curl -f style non-zero on 4xx
                    badpage) printf '<!DOCTYPE html><html><head><title>Please sign in</title></head><body>login</body></html>' ;;
                    *) printf '%s\n' "${MOCK_EXEC_OUT:-ok}" ;;
                esac ;;
            *) printf '%s\n' "${MOCK_EXEC_OUT:-ok}" ;;
        esac ;;
    *"rollout restart"*)
        echo 'deployment.apps/app restarted' ;;
    *"rollout status"*)
        echo 'deployment "app" successfully rolled out' ;;
    *"delete pod"*)
        echo 'pod "pod-a" deleted' ;;
    *" cp "*)
        exit 0 ;;
    *"logs"*"--previous"*)
        printf 'Exception in thread "main" java.lang.OutOfMemoryError: Java heap space\n\tat com.example.Boot.main(Boot.java:12)\n' ;;
    *"logs"*"--tail=200"*)
        # the TUI's live log pane; includes every severity the classifier knows
        printf '10:00:01 INFO  Started DebugDemoApplication in 3.2 seconds\n10:00:02 WARN  HikariPool-1 pool is near capacity\n10:00:03 ERROR java.lang.OutOfMemoryError: Java heap space\n\tat com.example.Leak.grow(Leak.java:42)\n10:00:04 INFO  request served in 12ms\n' ;;
    *"logs"*)
        echo 'mock log line' ;;
    *) exit 0 ;;
esac
