#!/usr/bin/env bash
#
# jdebug — the front door for the JVM debug kit. Cluster-agnostic: works
# against ANY Spring Boot pod on ANY cluster the ambient kubectl context
# points at (KUBECONFIG / kubectl config use-context — no auto-rewriting).
# Every command takes -n <ns> -l <selector> [--container <name>] [pod];
# defaults: namespace "default", any pod, container "app" (or the
# JDEBUG_NAMESPACE / JDEBUG_SELECTOR / JDEBUG_CONTAINER env vars).
#
# Run with NO arguments (or `tui`) for the interactive menu; `wizard` jumps
# straight into a guided, symptom-driven capture flow.
#
#   Triage (runbook steps 1–4)
#     status        pod status, restarts, recent events
#     health        actuator health, incl. per-subsystem + liveness/readiness
#     top           kubectl top pods + HPA state
#     metrics       list JVM/process metric names, or one metric's live value:
#                   metrics jvm.gc.pause — run twice to see a trend
#     why           pod deep-dive: limits, probes, exit codes, HPA (why.sh)
#     security      pod security posture, in plain language (security.sh)
#     topology      deployment → replicasets → pods + HPA/services (topology.sh)
#     workload      topology + why in one scroll — what the TUI's W key runs
#     context       app wiring: services, env, probes, volumes, deps (context.sh)
#     escalate      paste-ready handoff brief for asking for help (escalate.sh)
#     timeline      pod events + your captures, in time order (timeline.sh)
#     what-changed  image/rollout/restart/scale after a deploy (what-changed.sh)
#     cleanup       remove files jdebug staged in the pod (--confirm) (cleanup.sh)
#     restart       re-roll the owning deployment (needs --confirm)
#     kill          delete a pod; managed pods respawn (needs --confirm)
#     logs          stream logs from all replicas         (tail-logs.sh)
#                   logs --previous [pod]: the crashed container's last lines
#     log-level     runtime logger change: log-level <logger> <LEVEL>
#
#   Capture (three tiers — actuator, jattach, jdk)
#     threads       thread dump. With no --via it AUTO-DEGRADES actuator → jattach
#                   → jdk (announcing each fallback); --via <tier> forces one.
#     heap          heap dump — PAUSES THE JVM, needs --confirm; same tiers/auto.
#     jcmd          any jcmd command via jattach: jcmd "GC.heap_info"
#     fetch-heap    retrieve the hprof the JVM wrote ON CRASH (OOMKilled pods:
#                   the only heap that exists is the one written on the way
#                   down — needs -XX:+HeapDumpOnOutOfMemoryError; fetch-heap
#                   explains the setup when it finds nothing). Read-only.
#
#   Actuator path defaults to http://localhost:8080/actuator (in the pod).
#   Override with --actuator-base <url> or $ACTUATOR_BASE when it differs
#   (custom management port/base-path, e.g. --actuator-base http://localhost:9001/manage).
#
#   Memory / bundle (runbook steps 5–6)
#     memory        RSS vs JVM anatomy, reconciled        (memory-report.sh)
#     snapshot      one-shot offline-analysis bundle      (snapshot.sh)
#     dumps         list everything captured so far + how to analyze each
#     analyze       first-pass read of ALL captures: deadlocks, blocked
#                   threads, DOWN health, OOM risk, invalid dumps
#
#   Every capture lands under this kit's dumps/ directory (git-ignored);
#   `jdebug dumps` shows what you have and what to open it with.
#
#   Setup
#     doctor            check everything BEFORE an incident: host tools, cluster
#                       reachability, target pods, container name, actuator
#                       capture endpoint, vendored jattach/core/TUI binaries
#     install-jattach   pre-stage jattach into the pod before an incident
#     push-local        copy the in-pod tool (jdebug-local) into the pod, for
#                       when you'll have a shell but no kubectl (JRE-only image)
#
# Examples:
#   jdebug threads                        # thread dump via the actuator tier
#   jdebug heap --confirm --via jattach
#   jdebug snapshot -n prod -l app=payments
#   jdebug jcmd "VM.native_memory summary"
#
# No kubectl inside the pod? See jdebug-local (a single POSIX-sh file that runs
# the same captures from within the container): jdebug push-local, then in the
# pod `sh /tmp/jdebug-local help`.

set -uo pipefail
# Resolve through symlinks so `jdebug` works when symlinked onto PATH (install.sh).
_src="${BASH_SOURCE[0]}"
while [ -L "$_src" ]; do _d="$(cd -P "$(dirname "$_src")" && pwd)"; _src="$(readlink "$_src")"; [[ $_src == /* ]] || _src="$_d/$_src"; done
D="$(cd -P "$(dirname "$_src")" && pwd)"
# shellcheck source=lib/common.sh
source "$D/lib/common.sh"
# lib/common.sh turns errexit ON (its leaf scripts want that); this dispatcher
# is written for `set -uo pipefail` with EXPLICIT rc handling — under errexit,
# the tier cascade in capture() dies before its rc=$? line, and a failing
# optional probe (events RBAC, /health/liveness 404) kills status/health
# before their "Bottom line" guidance prints. Restore the dispatcher's mode.
set +e

JDEBUG_VERSION="1.0.0"

usage_top() { sed -n '2,/^set /p' "$0" | sed '$d' | sed 's/^# \{0,1\}//'; }

cmd="${1:-}"; shift 2>/dev/null || true

# Extract --via <tier> (threads/heap) and --actuator-base <url>; pass the rest on.
VIA="actuator"; VIA_EXPLICIT=0
: "${ACTUATOR_BASE:=http://localhost:8080/actuator}"; export ACTUATOR_BASE
ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --via)           VIA="$2"; VIA_EXPLICIT=1; shift 2 ;;
        --actuator-base) ACTUATOR_BASE="$2"; export ACTUATOR_BASE; shift 2 ;;
        *)     ARGS+=("$1"); shift ;;
    esac
done
# bash 3.2 (stock macOS) empty-array guard
fwd() { "$@" ${ARGS[@]+"${ARGS[@]}"}; }

triage_parse() { parse_common_args ${ARGS[@]+"${ARGS[@]}"}; }

# run_tier <tier> <threads|heap> — invoke exactly one capture tier.
run_tier() {
    case "$1" in
        actuator) fwd "$D/capture/actuator.sh" "$2" ;;
        jattach)  fwd "$D/capture/jattach.sh"  "$2" ;;
        jdk)      if [[ "$2" == threads ]]; then fwd "$D/capture/jdk-threads.sh"; else fwd "$D/capture/jdk-heap.sh"; fi ;;
        *) err "unknown --via '$1' (actuator|jattach|jdk)"; exit 64 ;;
    esac
}
# capture <threads|heap> — an explicit --via runs only that tier; otherwise DEGRADE
# AUTOMATICALLY actuator → jattach → jdk, announcing each fallback to the terminal.
capture() {
    # A missing --confirm must read as exactly that — if it fell through to
    # the tiers, all three would refuse (same gate) and the cascade would
    # report "all capture tiers failed", blaming the cluster for a flag.
    if [[ "$1" == heap ]]; then
        local _c=0 _a
        for _a in ${ARGS[@]+"${ARGS[@]}"}; do [[ "$_a" == "--confirm" ]] && _c=1; done
        if [[ "$_c" -ne 1 ]]; then
            err "heap dumps pause the JVM (destructive in production). Re-run with --confirm."
            exit 64
        fi
    fi
    if [[ "$VIA_EXPLICIT" == 1 ]]; then run_tier "$VIA" "$1"; return $?; fi
    # exit 2 = target resolution failed (no pod matched, or an ambiguous match
    # on a destructive op) — no tier can fix a target problem, so don't cascade.
    # `|| rc=$?` (not `cmd; rc=$?`): errexit-proof, so the cascade still runs
    # even if a sourced library re-enables set -e.
    local rc=0
    run_tier actuator "$1" || rc=$?
    [[ $rc -eq 0 ]] && return 0
    [[ $rc -eq 2 ]] && return 2
    info "⚠ actuator tier failed — auto-falling back to jattach (needs no actuator)…"
    rc=0
    run_tier jattach "$1" || rc=$?
    [[ $rc -eq 0 ]] && return 0
    [[ $rc -eq 2 ]] && return 2
    info "⚠ jattach tier failed — auto-falling back to an ephemeral JDK container…"
    if run_tier jdk "$1"; then return 0; fi
    err "all capture tiers failed (actuator → jattach → jdk); see the errors above."
    return 1
}

# resolve_tui_binary lives in lib/common.sh so every entry point — this CLI AND
# observe/analyze.sh — resolves the SAME checksum-verified binary. Call it with
# the kit root: resolve_tui_binary "$D".

# Interactive frontends (menu, wizard) need a real terminal. On a pipe/redirect
# — CI, cron, `expect`, `jdebug wizard </dev/null` smoke tests — the TUI would
# spray escape sequences into the stream and then block on input forever. Fail
# loud with a next step instead of hanging.
case "$cmd" in
    tui|menu|""|wizard|guide)
        if [[ ! -t 0 ]]; then
            err "interactive mode needs a terminal, but stdin is not a TTY (pipe/redirect/CI)."
            err "  for scripts, call a specific verb:  jdebug doctor | status | threads | analyze"
            err "  (jdebug --help lists them all)"
            exit 64
        fi ;;
esac

# Preflight: every cluster-touching command checks connectivity first and
# explains failures in plain language (check_cluster, lib/common.sh) rather
# than surfacing raw kubectl TLS/connection noise mid-command.
case "$cmd" in
    status|health|top|metrics|threads|heap|jcmd|memory|snapshot|logs|log-level|install-jattach|push-local|fetch-heap)
        check_cluster || exit 3 ;;
esac

# v2 capture engine (Go core): a local `make core` build if present, else the
# checksum-verified vendored binary in tools/core. Resolved once here so every
# capture verb routes to the same binary.
#   CORE_RC=0 → verified, use it            CORE_RC=1 → absent, v1 tiers take over
#   CORE_RC=2 → PRESENT BUT FAILED VERIFICATION — capture verbs refuse to run
#   (a tampered/corrupt engine must not silently degrade to the v1 tiers).
CORE_RC=0
CORE_BIN="$(resolve_core_binary "$D")" || { CORE_RC=$?; CORE_BIN=""; }
# require_core_ok — called by capture verbs before choosing an engine.
require_core_ok() {
    if [[ "$CORE_RC" -eq 2 && -z "${JDEBUG_V1:-}" ]]; then
        err "the v2 capture engine is present but failed verification (details above) — refusing"
        err "  to run it, and refusing to fall back silently."
        err "  fix it:   git checkout -- tools/core   (or: make core)"
        err "  or force the v1 bash tiers deliberately:   JDEBUG_V1=1 jdebug <command>"
        exit 1
    fi
}

# --via passes through to the core only when the user set it explicitly. An array
# (not an unquoted command substitution) keeps it two args or none without the
# word-splitting shellcheck rightly flags.
VIA_FLAG=()
[[ "$VIA_EXPLICIT" == 1 ]] && VIA_FLAG=(--via "$VIA")

case "$cmd" in
    tui|menu|"")
        TUI_BIN="$(resolve_tui_binary "$D")" || exit 1
        JDEBUG_KIT="$D" exec "$TUI_BIN" ;;
    wizard|guide)
        TUI_BIN="$(resolve_tui_binary "$D")" || exit 1
        JDEBUG_KIT="$D" exec "$TUI_BIN" -start wizard ;;

    status)
        triage_parse
        show_cmd kubectl -n "$NAMESPACE" get pods ${SELECTOR:+-l "$SELECTOR"} -o wide
        PODS_OUT="$(kubectl -n "$NAMESPACE" get pods ${SELECTOR:+-l "$SELECTOR"} -o wide 2>&1)" || true
        printf '%s\n' "$PODS_OUT"
        echo
        show_cmd kubectl -n "$NAMESPACE" get events --sort-by=.lastTimestamp "| tail -15"
        # events RBAC is often restricted — a denied/failed events read must not
        # kill this command (the decision guidance below is the whole point).
        EV_RC=0
        EV_OUT="$(kubectl -n "$NAMESPACE" get events --sort-by=.lastTimestamp 2>&1 | tail -15)" || EV_RC=$?
        if [[ $EV_RC -ne 0 ]]; then
            echo "  (events not readable here — usually events RBAC; the pod table above still tells the story)"
        else
            printf '%s\n' "$EV_OUT"
        fi
        echo
        echo "how to read this:"
        echo "  RESTARTS climbing         → the app keeps dying; the events above + logs say why"
        echo "  STATUS CrashLoopBackOff   → dying right at startup, k8s is waiting to retry — check logs"
        echo "  'OOMKilled' in events     → ran out of memory — run the wizard's OOM flow (w → 1)"
        echo "  STATUS Pending            → can't be scheduled — usually resources or image pull"
        # decision-oriented tail, computed from the table above
        BOTTOM=""; NEXT=""
        MAXR="$(awk 'NR>1 {gsub(/[^0-9].*/,"",$4); if ($4+0>m) m=$4+0} END {print m+0}' <<<"$PODS_OUT")"
        if grep -q 'CrashLoopBackOff' <<<"$PODS_OUT"; then
            BOTTOM="the app is crash-looping — it dies at (or right after) startup."
            NEXT="jdebug logs --previous    (the dead container's last words — or w → 7 in the menu)"
        elif grep -qE '[[:space:]]Pending[[:space:]]' <<<"$PODS_OUT"; then
            BOTTOM="pod(s) can't be scheduled — the cluster hasn't found them a home yet."
            NEXT="read the events above — not-enough-resources and image pulls are the usual causes"
        elif [[ "${MAXR:-0}" -gt 3 ]]; then
            BOTTOM="pods are up right now, but restarts are climbing ($MAXR so far) — something keeps killing them."
            NEXT="w in the menu (guided diagnosis) — or jdebug logs --previous for the last crash"
        elif grep -q 'Running' <<<"$PODS_OUT"; then
            BOTTOM="pods look healthy right now."
            NEXT="jdebug health    (a DOWN dependency explains a sick-but-running app)"
        fi
        if [[ -n "$BOTTOM" ]]; then
            echo
            echo "Bottom line: $BOTTOM"
            echo "Next:        $NEXT"
        fi
        ;;

    health)
        triage_parse
        POD="$(resolve_one_pod "${REMAINING_ARGS[0]:-}")" || exit $?
        # curl-or-wget in the pod, against $ACTUATOR_BASE (adjustable via
        # --actuator-base). Not pod_fetch: health must show the 503-with-body a
        # DOWN status returns, so no curl -f here.
        hfetch() { kubectl -n "$NAMESPACE" exec "$POD" -c "$APP_CONTAINER" -- sh -c "if command -v curl >/dev/null 2>&1; then curl -sS '$1'; else wget -qO- '$1'; fi"; }
        show_cmd "kubectl -n $NAMESPACE exec $POD -c $APP_CONTAINER -- sh -c '<curl-or-wget> $ACTUATOR_BASE/health'"
        BODY="$(hfetch "$ACTUATOR_BASE/health" || true)"
        if [[ -z "$BODY" ]]; then
            err "no response from $ACTUATOR_BASE/health in pod $POD"
            err "  → wrong port/path? pass --actuator-base <url>"
            err "  → actuator absent or secured? captures still work without it: --via jattach"
            exit 3
        fi
        if [[ "$BODY" != *'"status"'* ]]; then
            err "the response from $ACTUATOR_BASE/health doesn't look like actuator health output:"
            printf '%s\n' "$BODY" | head -3 | sed 's/^/    /' >&2
            err "  → something else answers on that port — wrong port/path? pass --actuator-base <url>"
            err "  → not a Spring Boot app? captures still work without actuator: --via jattach"
            exit 3
        fi
        if command -v python3 >/dev/null 2>&1; then
            printf '%s' "$BODY" | python3 -m json.tool 2>/dev/null || printf '%s\n' "$BODY"
        else
            printf '%s\n' "$BODY"
        fi
        # the liveness/readiness health GROUPS are optional in Spring Boot —
        # a 404 here is normal and must not kill the verdict below.
        for probe in liveness readiness; do
            printf '%-10s: ' "$probe"
            hfetch "$ACTUATOR_BASE/health/$probe" 2>/dev/null || printf '(not exposed — optional probe group, this is normal)'
            echo
        done
        echo
        echo 'how to read this: overall "UP" = the app thinks it is healthy. A DOWN component'
        echo '(db, redis, jms, …) names the dependency that is failing — chase that system first,'
        echo 'the JVM is usually just the victim.'
        echo
        if [[ "$BODY" == *'DOWN'* ]]; then
            echo "Bottom line: the app is reachable but a dependency it needs is DOWN (named above)."
            echo "Next:        chase that system first — the JVM is usually just the victim."
        else
            echo "Bottom line: the app says it is healthy — dependencies included."
            echo "Next:        users still seeing problems? then it's load or latency, not health: w → 2"
        fi
        ;;

    top)
        triage_parse
        show_cmd kubectl -n "$NAMESPACE" top pods
        kubectl -n "$NAMESPACE" top pods 2>/dev/null || echo "  (metrics-server not answering)"
        echo
        show_cmd kubectl -n "$NAMESPACE" get hpa
        kubectl -n "$NAMESPACE" get hpa 2>/dev/null || echo "  (no HPA in $NAMESPACE)"
        echo
        echo "how to read this: MEMORY near the pod's limit → OOM risk; CPU pinned at the"
        echo "limit → throttling makes everything slow."
        echo
        echo "Next: memory near the limit → jdebug memory · CPU pinned → w → 3 (hot-loop hunt)"
        ;;

    metrics)
        triage_parse
        METRIC="${REMAINING_ARGS[0]:-}"
        POD="$(resolve_one_pod "${REMAINING_ARGS[1]:-}")" || exit $?
        mfetch() { kubectl -n "$NAMESPACE" exec "$POD" -c "$APP_CONTAINER" -- sh -c "$(pod_fetch "$1")"; }
        mfail() { err "actuator metrics not reachable at $ACTUATOR_BASE in pod $POD (wrong port/path? secured?) — try --actuator-base"; exit 1; }
        if [[ -n "$METRIC" ]]; then
            show_cmd "kubectl -n $NAMESPACE exec $POD -c $APP_CONTAINER -- sh -c '<curl-or-wget> $ACTUATOR_BASE/metrics/$METRIC'"
            if command -v python3 >/dev/null 2>&1; then
                mfetch "$ACTUATOR_BASE/metrics/$METRIC" | python3 -m json.tool 2>/dev/null || mfail
            else
                mfetch "$ACTUATOR_BASE/metrics/$METRIC" || mfail; echo
            fi
        else
            show_cmd "kubectl -n $NAMESPACE exec $POD -c $APP_CONTAINER -- sh -c '<curl-or-wget> $ACTUATOR_BASE/metrics'"
            # three expressions, not \| alternation — BSD sed (stock macOS) has no \|
            mfetch "$ACTUATOR_BASE/metrics" | tr ',' '\n' | sed -n 's/.*"\(jvm[^"]*\)".*/  \1/p; s/.*"\(process[^"]*\)".*/  \1/p; s/.*"\(system[^"]*\)".*/  \1/p' | sort -u || mfail
            echo
            echo "show one:  jdebug metrics <name>   (e.g. jvm.gc.pause, jvm.memory.used, process.cpu.usage)"
        fi
        ;;

    # Capture verbs: the Go core (core/jdebug-core, `make core`) is the v2
    # engine — typed destructive-target gate, unskippable validation, manifest
    # provenance. It takes over when built; JDEBUG_V1=1 forces the bash tiers.
    threads)
        require_core_ok
        if [[ -z "${JDEBUG_V1:-}" && -n "$CORE_BIN" ]]; then
            JDEBUG_KIT="$D" exec "$CORE_BIN" threads \
                ${VIA_FLAG[@]+"${VIA_FLAG[@]}"} ${ARGS[@]+"${ARGS[@]}"}
        fi
        capture threads ;;
    heap)
        require_core_ok
        if [[ -z "${JDEBUG_V1:-}" && -n "$CORE_BIN" ]]; then
            JDEBUG_KIT="$D" exec "$CORE_BIN" heap \
                ${VIA_FLAG[@]+"${VIA_FLAG[@]}"} ${ARGS[@]+"${ARGS[@]}"}
        fi
        capture heap ;;

    fetch-heap)
        # F7: retrieve the hprof the JVM wrote on OOM (needs the core: make core)
        require_core_ok
        if [[ -n "$CORE_BIN" ]]; then
            JDEBUG_KIT="$D" exec "$CORE_BIN" fetch-heap ${ARGS[@]+"${ARGS[@]}"}
        fi
        err "fetch-heap needs the v2 engine — build it once: make core (needs Go)"
        exit 1 ;;
    jcmd)
        require_core_ok
        if [[ -z "${JDEBUG_V1:-}" && -n "$CORE_BIN" ]]; then
            JDEBUG_KIT="$D" exec "$CORE_BIN" jcmd ${ARGS[@]+"${ARGS[@]}"}
        fi
        fwd "$D/capture/jattach.sh" jcmd ;;
    why)             fwd "$D/observe/why.sh" ;;
    security)        fwd "$D/observe/security.sh" ;;
    topology)        fwd "$D/observe/topology.sh" ;;
    # workload = the whole picture in one scroll: the topology tree (what owns
    # the pod, rollout state, HPA, services) THEN the why deep-dive (limits,
    # probes, exit codes, autoscaling). `why` and `topology` remain on their own
    # for anyone who wants just one half.
    workload)        fwd "$D/observe/topology.sh"; echo; fwd "$D/observe/why.sh" ;;
    context|wiring)  fwd "$D/observe/context.sh" ;;
    escalate|handoff) fwd "$D/observe/escalate.sh" ;;
    timeline)        fwd "$D/observe/timeline.sh" ;;
    what-changed|changed) fwd "$D/observe/what-changed.sh" ;;
    cleanup)         fwd "$D/observe/cleanup.sh" ;;
    restart)         fwd "$D/observe/lifecycle.sh" restart ;;
    kill)            fwd "$D/observe/lifecycle.sh" kill ;;
    memory)          fwd "$D/observe/memory-report.sh" ;;
    snapshot)
        require_core_ok
        if [[ -z "${JDEBUG_V1:-}" && -n "$CORE_BIN" ]]; then
            JDEBUG_KIT="$D" exec "$CORE_BIN" snapshot ${ARGS[@]+"${ARGS[@]}"}
        fi
        fwd "$D/observe/snapshot.sh" ;;

    analyze)         "$D/observe/analyze.sh" ${ARGS[@]+"${ARGS[@]}"} ;;

    dumps|captures)
        echo "Captured evidence — $JDEBUG_DUMPS (organized by pod → session → file)"
        echo
        # Walk the organized tree: dumps/pods/<pod>/<ts>/<files>. A session dir
        # with a .snapshot marker is a bundle; otherwise it's single captures.
        # `|| true`: common.sh sets -e; a missing dir must mean "none yet".
        found=0
        if [[ -d "$JDEBUG_DUMPS/pods" ]]; then
            while IFS= read -r pod; do
                [[ -z "$pod" ]] && continue
                found=1
                printf '  %s/\n' "$(basename "$pod")"
                while IFS= read -r ts; do
                    [[ -z "$ts" ]] && continue
                    kind="session"; [[ -f "$ts/.snapshot" ]] && kind="snapshot bundle"
                    nfiles=$(find "$ts" -type f ! -name '.*' ! -name manifest.json 2>/dev/null | wc -l | tr -d ' ')
                    printf '    %s/   (%s, %s file(s))\n' "$(basename "$ts")" "$kind" "$nfiles"
                    find "$ts" -type f ! -name '.*' ! -name manifest.json 2>/dev/null | sort | while IFS= read -r f; do
                        printf '      %6s  %s\n' "$(du -h "$f" 2>/dev/null | cut -f1 | tr -d ' ')" "$(basename "$f")"
                    done
                done < <(find "$pod" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort -r)
            done < <(find "$JDEBUG_DUMPS/pods" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
        fi
        # legacy flat layout (pre-reorg dumps) — still list it if present
        legacy="$(cd "$JDEBUG_DUMPS" 2>/dev/null && find . -maxdepth 2 \( -path './pods' -o -name 'session-*' \) -prune -o -type f -print 2>/dev/null | sed 's|^\./||')" || true
        [[ -n "$legacy" ]] && { found=1; echo "  (older flat captures:)"; printf '    %s\n' $legacy; }
        if [[ "$found" -eq 0 ]]; then
            echo "  none yet — threads, heap, and snapshot save their files here automatically."
            echo "  Try: jdebug threads   (safe, instant)"
            exit 0
        fi
        cat <<'HINTS'

  These files are already on YOUR machine. How to analyze each kind:
    threads-*.txt     'jdebug analyze <file>' flags deadlocks, blocked pools, hot loops;
                      deeper: VisualVM (free, local — visualvm.github.io)
    heap-*.hprof      'jdebug analyze <file>' prints a class histogram (biggest consumers);
                      deeper: Eclipse MAT → Open Heap Dump → "Leak Suspects"
    why.txt/security.txt   the kubernetes-layer findings, already summarized
    session-*.log     transcript of everything you ran in the menu (and its output)

  ⚠ Heap dumps contain whatever the app had in memory — possibly real user data.
    Treat them like production data; delete them when the investigation is done.

  Analyze one session:  jdebug analyze <dir>   ·   everything:  jdebug analyze
HINTS
        ;;
    logs)            fwd "$D/observe/tail-logs.sh" ;;
    log-level)       fwd "$D/observe/set-log-level.sh" ;;
    install-jattach) fwd "$D/capture/jattach.sh" install ;;

    push-local)
        triage_parse
        POD="$(resolve_one_pod "${REMAINING_ARGS[0]:-}")" || exit $?
        show_cmd kubectl -n "$NAMESPACE" cp "$D/jdebug-local" "$POD:/tmp/jdebug-local" -c "$APP_CONTAINER"
        if kubectl -n "$NAMESPACE" cp "$D/jdebug-local" "$POD:/tmp/jdebug-local" -c "$APP_CONTAINER"; then
            info "staged jdebug-local at $POD:/tmp/jdebug-local — now: kubectl -n $NAMESPACE exec -it $POD -c $APP_CONTAINER -- sh /tmp/jdebug-local help"
            record_artifact 1 "/tmp/jdebug-local" "in-pod tool (jdebug-local)"
        else
            err "cp failed (no tar in the pod? paste the script into the shell instead)"
        fi
        ;;

    doctor|checkup)
        triage_parse
        FAILS=0; WARNS=0
        chk() { printf '  ✓ %s\n' "$1"; }
        wrn() { printf '  ! %s\n' "$1"; WARNS=$((WARNS+1)); }
        bad() { printf '  ✗ %s\n' "$1"; FAILS=$((FAILS+1)); }
        echo "jdebug doctor — checking this machine, the cluster, and the target"
        echo
        echo "host"
        command -v kubectl >/dev/null 2>&1 && chk "kubectl on PATH" \
            || bad "kubectl missing — install it and/or add it to PATH"
        command -v python3 >/dev/null 2>&1 && chk "python3 on PATH" \
            || wrn "python3 missing — 'jdebug memory' won't run; every other command is fine"
        if mkdir -p "$JDEBUG_DUMPS" 2>/dev/null && [[ -w "$JDEBUG_DUMPS" ]]; then
            chk "captures dir writable ($JDEBUG_DUMPS)"
        else
            bad "cannot write the captures dir ($JDEBUG_DUMPS) — set \$JDEBUG_DUMPS elsewhere"
        fi
        # jattach ships IN this repo (vendored, pinned, checksummed) — no
        # download, ever. Verify both binaries against SHA256SUMS right here,
        # so a corrupted/tampered copy is caught BEFORE an incident.
        JAT_VENDOR="${JATTACH_VENDOR_DIR:-$D/vendor/jattach}"
        if ls "$JAT_VENDOR"/jattach-linux-* >/dev/null 2>&1; then
            if [[ -f "$JAT_VENDOR/SHA256SUMS" ]] && command -v sha256sum >/dev/null 2>&1 \
                    && (cd "$JAT_VENDOR" && sha256sum -c SHA256SUMS >/dev/null 2>&1); then
                chk "jattach vendored + checksums verified ($JAT_VENDOR) — tier 2 needs no network"
            elif [[ -f "$JAT_VENDOR/SHA256SUMS" ]] && command -v shasum >/dev/null 2>&1 \
                    && (cd "$JAT_VENDOR" && shasum -a 256 -c SHA256SUMS >/dev/null 2>&1); then
                chk "jattach vendored + checksums verified ($JAT_VENDOR) — tier 2 needs no network"
            elif [[ ! -f "$JAT_VENDOR/SHA256SUMS" ]]; then
                bad "vendored jattach has no SHA256SUMS ($JAT_VENDOR) — installs will refuse; restore it from git"
            else
                bad "vendored jattach FAILS its checksums ($JAT_VENDOR) — modified/corrupt; restore from git"
            fi
        else
            wrn "vendored jattach binaries missing ($JAT_VENDOR) — the jattach tier can't install;"
            wrn "  restore vendor/jattach/ from git, or pass --binary /path/to/jattach per run"
        fi
        # capture engine + interactive frontend: say which engine captures will
        # use, and catch a broken TUI BEFORE `jdebug` (no args) fails on it.
        if [[ "$CORE_RC" -eq 2 ]]; then
            bad "v2 capture engine present but FAILED verification (details above) — capture verbs"
            bad "  will refuse until fixed: git checkout -- tools/core  (or: make core)"
        elif [[ -n "$CORE_BIN" ]]; then
            chk "v2 capture engine ready ($(basename "$CORE_BIN"), checksum-verified)"
        else
            wrn "v2 capture engine not available for this platform — captures use the v1 bash tiers"
            wrn "  (build it once for the better engine: make core — needs Go)"
        fi
        if resolve_tui_binary "$D" >/dev/null 2>&1; then
            chk "interactive menu/wizard (TUI) ready"
        else
            wrn "the interactive menu/wizard binary is unavailable — 'jdebug' (no args) and"
            wrn "  'jdebug wizard' won't start; every plain CLI verb still works."
            wrn "  build it: make tui   (needs Go — or restore vendor/tui/ from git)"
        fi
        echo
        echo "cluster"
        if check_cluster >/dev/null 2>&1; then
            chk "context '$(kubectl config current-context 2>/dev/null)' answers"
            PODS_FOUND="$(resolve_pods 2>/dev/null | grep -c . || true)"
            if [[ "${PODS_FOUND:-0}" -gt 0 ]]; then
                chk "$PODS_FOUND pod(s) match namespace=$NAMESPACE selector='${SELECTOR:-<any>}'"
                DOC_POD="$(resolve_pods 2>/dev/null | head -n1)"
                # container FIRST: if $APP_CONTAINER doesn't exist, every in-pod
                # check below would fail and read like an actuator problem.
                DOC_CONTAINERS="$(kubectl -n "$NAMESPACE" get pod "$DOC_POD" -o jsonpath='{.spec.containers[*].name}' 2>/dev/null | tr '\n' ' ' || true)"
                DOC_C_OK=1
                if [[ -z "${DOC_CONTAINERS// /}" ]]; then
                    wrn "couldn't list containers in $DOC_POD (RBAC?) — in-pod checks below may mislead"
                elif [[ " $DOC_CONTAINERS " == *" $APP_CONTAINER "* ]]; then
                    chk "container '$APP_CONTAINER' exists in $DOC_POD"
                else
                    DOC_C_OK=0
                    bad "no container named '$APP_CONTAINER' in $DOC_POD (it has: $DOC_CONTAINERS)"
                    printf '      → jdebug defaults to '\''app'\''. Set the real name: --container <name>,\n'
                    printf '        JDEBUG_CONTAINER=<name>, or the menu'\''s target editor (k)\n'
                fi
                if [[ "$DOC_C_OK" -eq 1 ]] && kubectl -n "$NAMESPACE" exec "$DOC_POD" -c "$APP_CONTAINER" -- \
                        sh -c "$(pod_fetch "$ACTUATOR_BASE/health")" >/dev/null 2>&1; then
                    chk "actuator answers in $DOC_POD ($ACTUATOR_BASE)"
                    # /health up is NOT tier-1-ready: stock Spring Boot exposes ONLY
                    # /health over HTTP — the capture endpoint needs opting in. Probe it.
                    TD_CODE="$(kubectl -n "$NAMESPACE" exec "$DOC_POD" -c "$APP_CONTAINER" -- \
                        sh -c "$(pod_http_status "$ACTUATOR_BASE/threaddump")" 2>/dev/null | tr -dc '0-9')"
                    case "$TD_CODE" in
                        200)
                            chk "capture endpoint $ACTUATOR_BASE/threaddump answers — tier 1 (actuator) ready" ;;
                        401|403)
                            wrn "capture endpoint /threaddump is SECURED (HTTP $TD_CODE) — tier 1 needs credentials:"
                            wrn "  export ACTUATOR_AUTH=bearer:ENV_VAR (or basic:USER_VAR:PASS_VAR) — menu: target editor (k)" ;;
                        404)
                            wrn "/health answers but /threaddump is NOT EXPOSED (HTTP 404) — tier 1 will fail."
                            wrn "  Stock Spring Boot exposes only /health; the app must opt in:"
                            wrn "    management.endpoints.web.exposure.include=health,threaddump,heapdump,metrics,loggers"
                            wrn "  Until then, captures use the jattach/jdk tiers automatically." ;;
                        *)
                            wrn "couldn't probe $ACTUATOR_BASE/threaddump (got: ${TD_CODE:-no reply}) — tier 1 unverified;"
                            wrn "  captures fall back to jattach/jdk automatically if it fails" ;;
                    esac
                elif [[ "$DOC_C_OK" -eq 1 ]]; then
                    wrn "actuator not answering at $ACTUATOR_BASE in $DOC_POD — the actuator tier won't"
                    wrn "  work there. Custom port/path? --actuator-base. No actuator at all? the"
                    wrn "  jattach tier needs none: jdebug install-jattach"
                fi
                if kubectl auth can-i patch pods/ephemeralcontainers -n "$NAMESPACE" >/dev/null 2>&1; then
                    chk "ephemeral containers allowed — tier 3 (jdk) available if tiers 1–2 fail"
                else
                    wrn "RBAC blocks ephemeral containers (pods/ephemeralcontainers) — tier 3 (jdk)"
                    wrn "  won't work here; tiers 1–2 (actuator, jattach) are unaffected"
                fi
            else
                bad "no pods match namespace=$NAMESPACE selector='${SELECTOR:-<any>}' — set -n/-l (or press t in the menu)"
            fi
        else
            bad "cluster unreachable — run any command (e.g. jdebug status) for the full why + fix"
        fi
        echo
        if [[ $FAILS -gt 0 ]]; then
            echo "✗ $FAILS problem(s) above need fixing before jdebug can fully work."
            exit 1
        elif [[ $WARNS -gt 0 ]]; then
            echo "✓ ready, with $WARNS note(s) above worth knowing."
        else
            echo "✓ everything checks out. Try: jdebug (menu) or jdebug wizard"
        fi
        ;;

    -h|--help)       usage_top ;;
    -V|--version)    echo "jdebug $JDEBUG_VERSION" ;;
    *) echo "unknown command: $cmd"; echo; usage_top; exit 64 ;;
esac
