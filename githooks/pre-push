#!/usr/bin/env bash
#
# pre-push — the hash-proof gate. Refuses to push when the vendored TUI
# binaries don't match their SHA256SUMS, or when SHA256SUMS was built from
# different tui/ sources than the ones being pushed. This is what makes the
# vendored binaries trustworthy to everyone who clones: what's in vendor/tui/
# is provably the build of the sources next to it.
#
# Install once: make hooks

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

[[ -d vendor/tui ]] || exit 0   # nothing vendored yet — nothing to prove

fail() { echo "pre-push: $*" >&2; echo "          fix: scripts/vendor-tui.sh && git commit" >&2; exit 1; }

[[ -f vendor/tui/SHA256SUMS ]] || fail "vendor/tui exists but has no SHA256SUMS"
[[ -f vendor/tui/BUILDINFO  ]] || fail "vendor/tui exists but has no BUILDINFO"

# 1. binaries match their recorded hashes
if command -v sha256sum >/dev/null 2>&1; then
    (cd vendor/tui && sha256sum -c SHA256SUMS >/dev/null 2>&1) || fail "vendored TUI binaries FAIL their checksums"
else
    (cd vendor/tui && shasum -a 256 -c SHA256SUMS >/dev/null 2>&1) || fail "vendored TUI binaries FAIL their checksums"
fi

# 2. the hashes were computed from THESE sources
src_now="$(cat tui/go.mod tui/go.sum $(ls tui/*.go | sort) | { command -v sha256sum >/dev/null 2>&1 && sha256sum || shasum -a 256; } | awk '{print $1}')"
src_rec="$(awk -F': ' '/^source_sha256/ {print $2}' vendor/tui/BUILDINFO)"
[[ "$src_now" == "$src_rec" ]] || fail "vendored TUI is STALE — built from different tui/ sources than this push"

echo "pre-push: vendored TUI verified (binaries match SHA256SUMS, sources match BUILDINFO)"

# same proof for the vendored v2 core engine, when present
if [[ -d tools/core ]]; then
    [[ -f tools/core/SHA256SUMS && -f tools/core/BUILDINFO ]] || fail "tools/core exists but is missing SHA256SUMS/BUILDINFO"
    if command -v sha256sum >/dev/null 2>&1; then
        (cd tools/core && sha256sum -c SHA256SUMS >/dev/null 2>&1) || fail "vendored core binaries FAIL their checksums"
    else
        (cd tools/core && shasum -a 256 -c SHA256SUMS >/dev/null 2>&1) || fail "vendored core binaries FAIL their checksums"
    fi
    core_now="$({ cat core/go.mod core/go.sum; find core -name '*.go' -not -name '*_test.go' | sort | xargs cat; } | { command -v sha256sum >/dev/null 2>&1 && sha256sum || shasum -a 256; } | awk '{print $1}')"
    core_rec="$(awk -F': ' '/^source_sha256/ {print $2}' tools/core/BUILDINFO)"
    [[ "$core_now" == "$core_rec" ]] || fail "vendored core is STALE — built from different core/ sources than this push"
    echo "pre-push: vendored core verified (binaries match SHA256SUMS, sources match BUILDINFO)"
fi
